  "keyFeatures": [
    "Financial dashboard with income, expense, and balance summary cards",
    "Interactive charts (bar, pie, donut) powered by Apache ECharts",
    "Transaction management with full CRUD operations",
    "Category management for organizing transactions",
    "Advanced filtering by year, month, category, and type",
    "Dark mode support with persistent user preference",
    "User profile with customizable avatar and username",
    "Responsive design with mobile and tablet support",
    "Brazilian Real (BRL) currency formatting"
  ],
  "publicApiSurface": [
    "GET /api/transactions",
    "POST /api/transactions",
